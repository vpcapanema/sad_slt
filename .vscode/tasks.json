{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SLT: Iniciar ambiente de desenvolvimento",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/start-dev.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "detail": "Sobe a API SLT na porta 8080, verifica conexoes (SIGMA) e abre o navegador"
    },
    {
      "label": "SLT: Subir banco PostgreSQL (Docker)",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/start-db.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "detail": "Container slt_postgres (PostGIS) na porta 5434 — separado do SIGMA-PLI"
    },
    {
      "label": "SLT: Aplicar schema PostgreSQL",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/apply-database.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "detail": "Reaplica cadastro_demanda + auditoria.log_sistema no container slt_postgres"
    }
  ]
}

# API local
PORT=8080

# SIGMA — API HTTP (instituições, pessoas)
SIGMA_API_BASE=http://56.125.163.194
SIGMA_HTTP_TIMEOUT=30

# SIGMA — PostgreSQL read-only (login admin → usuarios.usuario, perfil GESTOR)
# Mesmo padrão do PLI-HazardTrack. Copie a senha do .env de lá se já tiver.
SIGMA_POSTGRES_HOST=56.125.163.194
SIGMA_POSTGRES_PORT=5433
SIGMA_POSTGRES_DATABASE=sigma_pli_qr53
SIGMA_POSTGRES_USER=sigma_user
SIGMA_POSTGRES_PASSWORD=
SIGMA_POSTGRES_SSLMODE=disable
# Alternativa: SIGMA_DATABASE_URL=postgresql://sigma_user:senha@56.125.163.194:5433/sigma_pli_qr53?sslmode=disable

# Sessão admin (cookie). Gere: python -c "import secrets; print(secrets.token_hex(32))"
SLT_SESSION_SECRET=

# Banco SLT — container slt_postgres (porta 5434)
SLT_DATABASE_URL=postgresql://slt_user:slt_pass@127.0.0.1:5434/slt_db
